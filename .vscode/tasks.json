{
  "version": "2.0.0",
  "type": "shell",
  "tasks": [
    {
      "label": "Build Package (lint, compile, build)",
      "command": "npm run release",
      "group": {
        "kind":"build",
        "isDefault": true
      },
      "presentation": {
        "panel":"dedicated",
        "reveal": "always",
        "close": false,
        "clear": true,
        "showReuseMessage": true
      },
      "problemMatcher": ["$tsc-watch"]
    },
    {
      "label": "Run Tests",
      "command": "npm run test",
      "isBackground": false,
      "promptOnClose": false,
      "group": {
        "kind":"test",
        "isDefault": true
      },
      "presentation": {
        "panel":"dedicated",
        "reveal": "always",
        "close": false,
        "clear": true,
        "showReuseMessage": true
      },
    }
  ]
}
